* 전화번호 1개의 구조

 struct  tel  /* 전화번호의 구조, 총 103 byte */
 {
     char name[21];   /* 이름  21 Byte */

     char telnum[17]; /* 전화번호 17 Byte */

     int brate;       /* 전송속도 2 Byte
                         0 이면    1200 BPS,
                         1 이면    2400 BPS,
                         2 이면    4800 BPS,
                         3 이면    9600 BPS,
                         4 이면   19200 BPS,
                         5 이면   38400 BPS,
                         6 이면   57600 BPS,
                         7 이면  115200 BPS,
                         8 이면     110 BPS,
                         9 이면     150 BPS,
                        10 이면     300 BPS,
                        11 이면     600 BPS 이다.
                      */


     char parity;     /* 패리티 비트 1 Byte
                          Even 이면 'E',
                          Odd  이면 'O',
                          None 이면 'N' 이다. */

     int dbit;        /* 데이터비트 2 Byte
                          7 또는 8 이다. */

     int sbit;        /* 스톱비트   2 Byte
                          0 또는 1 이다. */

     int han;         /* 사용한글의 종류 2 Byte
                          0 이면  " 상용  조합형",
                          1 이면  " 삼성  조합형",
                          2 이면  " 금성  조합형",
                          3 이면  "옛 KS  조합형",
                          4 이면  "도깨비 조합형",
                          5 이면  "7 비트 완성형",
                          6 이면  "KS5601 완성형",
                          7 이면  " 영문  전용  "
                     */



     char hlp[56];   /* 비고의 내용 56 Byte
                        비고에는 '@' 로 시작하면 스크립트 파일
                        의 이름이 들어가고, '#'이 들어가면 이동
                        메뉴 파일의 이름이 들어간다.
                     */
 };

 * 'C' 언어로 나타내었을때의 구조

 struct setting
 {
     int  card;           /* 카드의 종류 */

     int  port;           /* COM Port의 번호 */

     int  brate;          /* 전송속도,  위에서 설명한 전화번호부의
                             전송속도의 형식과 같다.
                              0 이면    1200 BPS,
                              1 이면    2400 BPS,
                              2 이면    4800 BPS,
                              3 이면    9600 BPS,
                              4 이면   19200 BPS,
                              5 이면   38400 BPS,
                              6 이면   57600 BPS,
                              7 이면  115200 BPS,
                              8 이면     110 BPS,
                              9 이면     150 BPS,
                             10 이면     300 BPS,
                             11 이면     600 BPS 이다.
                          */


     int  parity;         /* Parity 비트
                             0 이면 EVEN
                             1 이면 ODD
                             2 이면 NONE
                               * 전화번호에서 쓰이는 것과는 다
                                 르다.
                          */

     int  tel_mode;      /* 전자식이면 0, 기계식이면 1 이다. */

     int  dbit;           /* 데이터 비트가 0 이면 7,
                                    1 이면 8 이다.       */

     int  sbit;           /* 정지비트가  0 또는 1 이다. */

     int  host_gul;      /* 위의 han 과 같다. 호스트의 한글 종\
                              류 */

     int  kbd;            /* 키보드의 종류
                             2 벌식은 0,
                             3 벌식은 1,
                             3 벌식-No Shift는 2 이다.
                          */

     int  h_fnt;          /* 한글폰트
                             굵은체는   0,
                             세벌식체는 1,


                             안상수체는 2 이다.
                          */

     int  e_fnt;          /* 영문폰트
                             명조체는     0,
                             굵은고딕체는 1,
                             진로만체는   2,
                             신명조체는   3 이다.
                          */

     int  wait_time;      /* 전화걸기의 기다림 시간 */

     char cmd[78];        /* 이야기의 초기화 명령 */

     int  terminal_type;  /* 터미널의 종류 */

     int  cursor_type;    /* 커서의 종류
                             0 이면  커서  없음,
                             1 이면  블럭  반짝임,
                             2 이면  블럭  고정,
                             3 이면  밑줄  반짝임,
                             4 이면  밑줄  고정 이다.
                          */

     int  mouse_use;      /* 다람쥐(Mouse)의 사용 여부 */

     int  mouse_cr;       /* 다람쥐(Mouse) 뒤에


                             CR 을 넣지 않으면 0 이고,
                             CR 을 넣으면 1 이다. */

     int  printer;        /* 프린터의 종류
                             0 이면 조합형 코드 프린터,
                             1 이면 완성형 코드 프린터이다.
                          */

     int  fast_start;     /* 이야기의 시작방식
                             0 이면 그냥 시작하고,
                             1 이면 빨리 시작한다.
                          */

     int  CR_LF_trans;    /* <CR>의 변환
                             0 이면 변환하지 않고,
                             1 이면 <CR> + <LF>로 바꾼다. */

     int  editor_cursor;  /* 문서편집기의 커서 종류
                             0 이면  커서  없음,
                             1 이면  블럭  반짝임,
                             2 이면  블럭  고정,
                             3 이면  밑줄  반짝임,
                             4 이면  밑줄  고정 이다.
                          */

     int  hang_delay;     /* 전화끊기의 대기시간 */


     int  break_delay;    /* Beeak 신호를 보내는 시간 */

     int  redial_delay;   /* 전화걸기 실패후 기다리는 시간 */

     int  hanja_conv;     /* 한자를 한글로 바꾸어 화면에 보일지
                             를 정한다. */

     char hanja_name[58]; /* 한자 파일의 이름과 경로 */

     char module_init[22];/* 프린터 초기화 명령 */

     char down_area[58];  /* 받기 목록 */

     char ext[4];         /* 문서편집기의 파일 확장자 */

     unsigned int gap;    /* 이야기의 글쇠 지연속도값 */

     int  backmake;      /*문서편집기의 백업파일(*.BAK) 만들기
                              0 이면 백업파일을 만들지 않고,
                              1 이면 백업파일을 만든다.*/

     char protocol[80];   /* 사용자 전송 프로토클의 이름 */

     char reserved[80];   /* 예약 영역 */

     char down_proargs[80]; /* 다운로드의 목록을 지정 */


     char color1, color2; /* 전경, 배경색 */

     char c_help1, c_help2; /* 도움말 색상 */

     char c_top1, c_top2; /* 풀다운 색깔 */

     char edit1, edit2;   /* 글틀 색깔 */

     char c_chat1, c_chat2; /* 채팅바 색깔 */

     char send_delay;     /* 보내기 지연 속도 */

     char auto_down;      /* 자동 다운로드, 접속파일의 기록 여
                             부를 정한다. 상위 4 bit는 자동다운
                             로드를 할지 정하고, 하위 4 bit는
                             접속파일을 만들지의 여부를 정한다.
                          */

     char grdsz;          /* DSZ를 화면상에서 받을지 도스로
                             받을지 정한다. */

     char sound_use;      /* 소리 켬/끔 지정 */

     char vga800;         /* 800 * 600 화면을 쓸 것인지 지정 */
     char bs_check;       /* BS 글쇠에서 한글검사를 할지 지정 (1이면 검사)*/
     char flow_control;   /* 0 : Flow control 검사 않음
                             1 : XON/OFF 검사
                             2 : CTS/RTS 검사
                             3 : XON/OFF, CTS/RTS 모두 검사 */
 };
