# IYAGI Terminal — connection settings
# Copy this file to .env and fill in your values.
# The launcher script sources this file automatically.
#
# Packaged builds (AppImage / installer) bundle this file as .env.example; on
# first run the launcher copies it to the user data dir (~/.local/share/iyagi-terminal/.env
# or iyagi-data/.env). So THIS file is the canonical default for new installs.
#
# When you tune DOSBox/bridge timing in iyagi-data/.env during dev, merge those
# changes back here (diff the two files) so releases match — but do NOT paste in
# secrets, one-off ports, or anything machine-specific; keep examples generic.

# Optional default SSH username. Leave blank to use host-only dial target.
IYAGI_USER=user

# SSH server port for bridge outbound connection (default: 22).
# Example for local SSH-BBS: IYAGI_SSH_PORT=40000
IYAGI_SSH_PORT=22

# SSH transport auth mode:
#   bbs - SSH-BBS style (default): do not use local key file, attempt open session
#         and let the BBS app do login inside the SSH terminal session.
#   key - traditional SSH key auth with local keypair in iyagi-data/keys/.
SSH_AUTH_MODE=bbs

# Local TCP port the bridge listens on.
# Use "auto" to pick an unused local port at launch time.
# If a fixed port is set but already in use, launchers auto-switch to a free one.
# IYAGI should dial the local bridge and include remote target in ATDT.
# Example: ATDT127.0.0.1:40000
BRIDGE_PORT=2323

# Linux video backend selection:
#   auto    - detect session type and fallback between wayland/x11
#   wayland - force Wayland backend
#   x11     - force X11 backend
DOSBOX_VIDEO_BACKEND=auto

# Linux/Wayland behavior in auto mode:
#   0 - on Wayland session, prefer x11 backend first (better title bar/decorations)
#   1 - strict Wayland first on Wayland session
DOSBOX_WAYLAND_STRICT=0

# Mouse capture defaults are configured to avoid trapping the host pointer:
# - seamless mode by default
# - middle-click releases/captures
# - Ctrl+F10 also toggles capture in DOSBox-Staging

# DOSBox binary source on Linux (non-AppImage / dev scripts):
#   auto    - prefer system dosbox if installed, else bundled dosbox in package
#   system  - force system dosbox from PATH
#   bundled - force bundled dosbox (usr/bin/dosbox inside package/AppImage)
# AppImage: always uses bundled Staging unless you export DOSBOX_SOURCE before
# starting the AppImage (this file's "auto" is ignored there on purpose).
DOSBOX_SOURCE=auto

# Optional absolute DOSBox executable path override (highest priority).
# Example:
# DOSBOX_BIN=/usr/games/dosbox
# DOSBOX_BIN=/usr/bin/dosbox-staging
# DOSBOX_BIN=

# DOSBox-X primary window size (used when DOSBOX_BIN points to dosbox-x).
# Smaller default than 1280x960 to avoid oversized window on laptops.
# Examples: 960x720, 1024x768, 1280x960
DOSBOX_X_WINDOWRES=1024x768

# DOSBox-X scaler:
#   normal2x forced   - crisp pixel-doubling
#   hq2x forced       - smoother upscale (default)
#   advinterp2x forced - smoother, lighter than hq2x
DOSBOX_X_SCALER="hq2x forced"

# DOSBox-X scanline emulation:
#   1/true/yes/on  - enable scanline-like scaler (uses DOSBOX_X_SCANLINE_SCALER)
#   0/false/no/off - disable (default)
DOSBOX_X_SCANLINES=0
# Recommended for visible scanlines:
#   scan2x forced (default), tv2x forced, rgb3x forced
DOSBOX_X_SCANLINE_SCALER="scan2x forced"
# OpenGL output usually renders scanline scalers more clearly in DOSBox-X.
DOSBOX_X_SCANLINE_OUTPUT=openglnb

# DOSBox-Staging scanline shader toggle (enabled by default):
#   1/true/yes/on  - use OpenGL output with a CRT/scanline GLSL shader
#   0/false/no/off - keep stable texture output path
DOSBOX_SCANLINES=1
# GLSL shader path/name for DOSBox-Staging when DOSBOX_SCANLINES is enabled.
# Run "dosbox --list-glshaders" to see available names.
# Presets (tune to taste):
#   Sharp:    crt/vga-1080p-fake-double-scan
#   Balanced: crt/vga-1080p
#   Soft:     crt/composite-1080p
DOSBOX_GLSHADER=crt/vga-1080p
# Window resolution used when DOSBOX_SCANLINES is enabled (2x target for 640x480).
DOSBOX_SCANLINE_WINDOWRES=1280x960

# DOSBox CPU timing (important for terminal cursor blink behavior):
#   Cursor-safe profile defaults:
#     DOSBOX_CPU_CORE=simple
#     DOSBOX_CPU_CPUTYPE=386
#     DOSBOX_CPU_CYCLES=1000   (interpreted as "fixed 1000"; lower = slower guest/cursor)
#   You can tune these values per machine if needed.
#   Common alternatives:
#     DOSBOX_CPU_CORE=normal
#     DOSBOX_CPU_CPUTYPE=486_slow
#     DOSBOX_CPU_CYCLES=1500~3000
#   DOSBOX_CPU_CYCLES can be:
#     4000        (interpreted as "fixed 4000")
#     fixed 4000  (explicit)
#     auto
DOSBOX_CPU_CORE=simple
DOSBOX_CPU_CPUTYPE=386
DOSBOX_CPU_CYCLES=1000
# DOSBox frame skipping (0-10):
#   0 = render every frame
#   1 = skip one frame between renders (helps tame overly fast software cursor blink)
DOSBOX_FRAMESKIP=1

# Bridge client->SSH text conversion:
#   euc-kr    - legacy Korean (Wansung) to UTF-8 (default)
#   cp949     - CP949/UHC to UTF-8
#   wansung   - alias of CP949/EUC-KR decoder
#   off       - disable conversion
BRIDGE_CLIENT_ENCODING=euc-kr

# Bridge SSH->client text conversion:
#   euc-kr    - UTF-8 to legacy Korean (Wansung) (default)
#   cp949     - UTF-8 to CP949-like stream (best effort via EUC-KR encoder)
#   wansung   - alias of EUC-KR encoding path
#   off       - disable conversion
BRIDGE_SERVER_ENCODING=euc-kr

# Repair common server-side UTF-8 mojibake echoes before legacy encoding.
# Keep enabled for many SSH-BBS text loops where echoed Korean appears as Ã­Â...
BRIDGE_SERVER_REPAIR_MOJIBAKE=1

# Rewrite ANSI reset code for legacy terminal clients:
#   1/true/yes/on  - replace ESC[0m with ESC[0;1;<default-fg>;<default-bg>m
#   0/false/no/off - keep server ANSI reset unchanged (preserve terminal defaults)
BRIDGE_ANSI_RESET_HACK=1

# Map modern ANSI color forms to classic ANSI (legacy DOS-friendly):
# - Converts SGR 39/49, 90-107, 38;5;n, 48;5;n, 38;2;r;g;b, 48;2;r;g;b
#   into classic ANSI color space.
# - SGR 39/49 are translated to SGR 0 (classic reset-to-default behavior).
# - Useful when BBS emits modern terminal colors.
BRIDGE_ANSI_COLOR_COMPAT_HACK=1

# Default classic ANSI colors used for "default fg/bg" semantics:
# - Applied when bridge sees SGR 39 (default fg), 49 (default bg),
#   and in reset rewrite expansion for SGR 0m.
# - Set to white on blue for IYAGI-like defaults.
#   Foreground range: 30-37
#   Background range: 40-47
BRIDGE_ANSI_DEFAULT_FG=37
BRIDGE_ANSI_DEFAULT_BG=44

# Mapping policy for SGR default-color codes (39/49):
#   sgr   - keep 39/49 as-is (true SGR semantics)
#   reset - map 39/49 to 0 (old reset semantics)
BRIDGE_ANSI_DEFAULT_MODE=reset

# Bridge debug logging:
#   1/true/yes/on - log client typing bytes during CONNECT (sensitive)
#   0/false/no/off - disable (default)
BRIDGE_DEBUG=0

# Mirror raw SSH server bytes directly to launcher stderr during CONNECT.
# This prints ANSI/newline bytes as-is so your terminal can render them.
# Useful to confirm whether the upstream server is actually sending color codes.
BRIDGE_DEBUG_RENDER_SERVER=0

# Ctrl+C behavior during CONNECT:
#   1/true/yes/on  - treat Ctrl+C as local hangup (returns NO CARRIER)
#   0/false/no/off - pass Ctrl+C through to remote SSH session
BRIDGE_CTRL_C_HANGUP=1

# ATDT connect timeout in seconds:
# If target host:port does not accept a TCP connection within this window,
# bridge immediately returns NO CARRIER after playing busy tone sequence.
BRIDGE_CONNECT_TIMEOUT_SEC=5

# Number of times to play busy.wav when target is unreachable/timeout.
BRIDGE_BUSY_REPEAT=5

# Silent gap between busy signal repeats (milliseconds).
# 0 means no extra gap between repeats.
BRIDGE_BUSY_GAP_MS=150

# Silent gap between DTMF digits during dial tone playback (milliseconds).
# Increase if the dial sequence sounds too fast.
BRIDGE_DTMF_GAP_MS=80

# Delay after DTMF sequence before CONNECT/BUSY signaling (milliseconds).
# For ATDT<number>, this enforces a short pause after digit tones.
BRIDGE_POST_DTMF_DELAY_MS=3000
